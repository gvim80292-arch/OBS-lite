{
  "name": "obs-lite",
  "version": "1.0.0",
  "description": "OBS Lite - Streaming App",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/gvim80292-arch/OBS-lite.git"
  },
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.obslite.app",
    "productName": "OBS Lite",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "src"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OBS Lite"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
